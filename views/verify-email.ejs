<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BizzDeal - Email Verification</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bizzdeal-bg-surface: #FFFFFF;
      --bizzdeal-text-primary: #0F172A;
      --bizzdeal-text-secondary: #64748B;
      --bizzdeal-gradient-primary: linear-gradient(90deg, #1565C0 0%, #2196F3 100%);
    }

    body {
      font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #F8FAFC;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      color: var(--bizzdeal-text-primary);
    }

    .container {
      background-color: var(--bizzdeal-bg-surface);
      border-radius: 26px;
      padding: 40px;
      max-width: 400px;
      width: 100%;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.14);
      text-align: center;
      margin: 20px;
    }

    .logo {
      max-width: 180px;
      margin-bottom: 30px;
    }

    .icon-container {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      margin: 0 auto 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
      background: #FFFFFF;
    }
    
    .icon-container img {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 12px;
      border-radius: 9999px;
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 24px;
    }

    .status-badge.success {
      background-color: #d1fae5;
      color: #059669;
    }

    .status-badge.error {
      background-color: #fee2e2;
      color: #dc2626;
    }

    h1 {
      font-size: 24px;
      font-weight: 700;
      margin: 0 0 16px;
    }

    p {
      color: var(--bizzdeal-text-secondary);
      font-size: 16px;
      line-height: 1.5;
      margin: 0 0 30px;
    }


  </style>
</head>
<body>
  <div class="container">
    <img src="https://api.bizzdeal.in/assets/logo-text.png" alt="BizzDeal" class="logo">
    
    <div class="icon-container">
      <img src="https://api.bizzdeal.in/assets/icon-only.jpg" alt="BizzDeal Icon">
    </div>

    <% if (success) { %>
      <div class="status-badge success">Verification Successful</div>
    <% } else { %>
      <div class="status-badge error">Verification Failed</div>
    <% } %>

    <h1><%= success ? 'Email Verified!' : 'Oops, something went wrong' %></h1>
    <p><%= message %></p>

  </div>

</body>
</html>
